# Core runtime
# Required for API auth (unless THUMBGATE_ALLOW_INSECURE=true in local isolated testing)
THUMBGATE_API_KEY=change-me
# THUMBGATE_API_KEY_ROTATED_AT=2026-03-12T00:00:00.000Z
# THUMBGATE_PUBLIC_APP_ORIGIN=https://thumbgate-production.up.railway.app
# THUMBGATE_BILLING_API_BASE_URL=https://thumbgate-production.up.railway.app
# THUMBGATE_FEEDBACK_DIR=/data/feedback
# THUMBGATE_GA_MEASUREMENT_ID=G-XXXXXXXXXX
# THUMBGATE_GOOGLE_SITE_VERIFICATION=google-site-verification-token

# Billing
# STRIPE_PUBLISHABLE_KEY=pk_live_change_me
# STRIPE_SECRET_KEY=sk_live_change_me
# STRIPE_SECRET_KEY_ROTATED_AT=2026-03-12T00:00:00.000Z
# STRIPE_PRODUCT_ID=prod_change_me
# STRIPE_PRICE_ID=price_change_me
# STRIPE_WEBHOOK_SECRET=whsec_change_me
# STRIPE_WEBHOOK_SECRET_ROTATED_AT=2026-03-12T00:00:00.000Z
# GITHUB_MARKETPLACE_WEBHOOK_SECRET=github_webhook_secret
# GITHUB_MARKETPLACE_WEBHOOK_SECRET_ROTATED_AT=2026-03-12T00:00:00.000Z
# THUMBGATE_GITHUB_MARKETPLACE_PLAN_PRICES_JSON={"1":{"amountCents":4900,"currency":"USD"}}

# Railway deploy
# RAILWAY_TOKEN=railway_token
# RAILWAY_TOKEN_ROTATED_AT=2026-03-12T00:00:00.000Z
# RAILWAY_PROJECT_ID=project_id
# RAILWAY_ENVIRONMENT_ID=environment_id
# RAILWAY_SERVICE=thumbgate
# RAILWAY_HEALTHCHECK_URL=https://thumbgate-production.up.railway.app/health

# Optional local paths
# THUMBGATE_FEEDBACK_DIR=.claude/memory/feedback
# THUMBGATE_CONTEXTFS_DIR=.claude/memory/feedback/contextfs
# THUMBGATE_REVENUE_LEDGER_PATH=.claude/memory/feedback/revenue-events.jsonl
# GH_PAT=github_pat_for_about_sync_and_secret_management

# Optional strictness toggles
# THUMBGATE_ALLOW_INSECURE=false
# THUMBGATE_ALLOW_EXTERNAL_PATHS=false
# THUMBGATE_SEMANTIC_CACHE_ENABLED=true
# THUMBGATE_SEMANTIC_CACHE_THRESHOLD=0.7
# THUMBGATE_SEMANTIC_CACHE_TTL_SECONDS=86400
# THUMBGATE_MEMORY_FIREWALL_PROVIDER=auto
# THUMBGATE_MEMORY_FIREWALL_MODE=strict

# Monthly budget cap in USD for paid operations (PaperBanana, etc.)
# THUMBGATE_MONTHLY_BUDGET_USD=10

# Optional LLM gateway routing (for paid hosted calls only)
# LLM_GATEWAY_BASE_URL=
# LLM_GATEWAY_API_KEY=
# TETRATE_API_KEY=

# ADK / GTM
# GEMINI_API_KEY=
# GEMINI_API_KEY_ROTATED_AT=2026-03-12T00:00:00.000Z

# Perplexity Max API (for marketing engine — npm run marketing)
# PERPLEXITY_API_KEY=pplx-...
# PERPLEXITY_API_KEY_ROTATED_AT=2026-03-12T00:00:00.000Z

# X.com / Twitter API (for automated posting — node scripts/post-to-x.js)
# X_API_KEY=
# X_API_KEY_ROTATED_AT=2026-03-12T00:00:00.000Z
# X_API_SECRET=
# X_API_SECRET_ROTATED_AT=2026-03-12T00:00:00.000Z
# X_ACCESS_TOKEN=
# X_ACCESS_TOKEN_ROTATED_AT=2026-03-12T00:00:00.000Z
# X_ACCESS_TOKEN_SECRET=
# X_ACCESS_TOKEN_SECRET_ROTATED_AT=2026-03-12T00:00:00.000Z

# Social analytics / Tessl distribution
# PLAUSIBLE_API_KEY=
# PLAUSIBLE_SITE_ID=thumbgate-production.up.railway.app
# TESSL_WORKSPACE=thumbgate

# X.com / Twitter analytics
# X_BEARER_TOKEN=
# X_USER_ID=

# Reddit API (for automated posting — node scripts/social-analytics/publishers/reddit.js)
# REDDIT_CLIENT_ID=
# REDDIT_CLIENT_SECRET=
# REDDIT_USERNAME=
# REDDIT_PASSWORD=

# Zernio unified social publishing API
# ZERNIO_API_KEY=sk_...

# Zernio connected account IDs
# ZERNIO_INSTAGRAM_ACCOUNT_ID=
# ZERNIO_TIKTOK_ACCOUNT_ID=
# ZERNIO_PROFILE_ID=
# ZERNIO_LINKEDIN_ACCOUNT_ID=
# ZERNIO_REDDIT_ACCOUNT_ID=
# ZERNIO_YOUTUBE_ACCOUNT_ID=

# LinkedIn (manual credentials for direct API fallback)
# LINKEDIN_EMAIL=
# LINKEDIN_PASSWORD=
