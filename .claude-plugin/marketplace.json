{
  "name": "mcp-memory-gateway",
  "version": "0.7.1",
  "plugins": [
    {
      "name": "mcp-memory-gateway",
      "description": "Pre-action gates that block AI agents from repeating known mistakes. Captures feedback, generates prevention rules, enforces them via PreToolUse hooks.",
      "type": "mcp",
      "source": {
        "type": "npm",
        "package": "mcp-memory-gateway",
        "command": "npx",
        "args": ["-y", "mcp-memory-gateway", "serve"]
      },
      "metadata": {
        "author": "Igor Ganapolsky",
        "homepage": "https://github.com/IgorGanapolsky/mcp-memory-gateway",
        "license": "MIT",
        "keywords": [
          "claude-desktop",
          "desktop-extension",
          "pre-action-gates",
          "ai-agent-safety",
          "mcp",
          "memory"
        ],
        "category": "developer-tools"
      }
    }
  ]
}
