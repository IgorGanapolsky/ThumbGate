{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node bin/cli.js hook-auto-capture"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash|Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node scripts/hook-pre-tool-use.js"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash scripts/hook-stop-self-score.sh"
          },
          {
            "type": "command",
            "command": "bash scripts/hook-stop-verify-deploy.sh"
          },
          {
            "type": "command",
            "command": "bash scripts/hook-stop-pr-thread-check.sh"
          },
          {
            "type": "command",
            "command": "node scripts/meta-agent-loop.js"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "mcp__thumbgate__feedback_stats|mcp__thumbgate__dashboard",
        "hooks": [
          {
            "type": "command",
            "command": "node bin/cli.js cache-update"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node bin/cli.js session-start"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "node bin/cli.js statusline-render"
  }
}
