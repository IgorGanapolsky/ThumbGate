{
  "name": "ThumbGate",
  "description": "Human-in-the-loop enforcement for AI coding agents with pre-action gates that block repeated mistakes.",
  "url": "https://thumbgate.ai",
  "hook_attributes": {
    "url": "https://thumbgate.ai/webhooks/github",
    "active": true
  },
  "redirect_url": "https://thumbgate.ai/github/callback",
  "callback_urls": [
    "https://thumbgate.ai/github/callback",
    "https://thumbgate.ai/auth/github"
  ],
  "setup_url": "https://thumbgate.ai/setup",
  "public": true,
  "default_permissions": {
    "contents": "read",
    "pull_requests": "read",
    "issues": "read",
    "workflows": "read"
  },
  "default_events": [
    "pull_request",
    "issues",
    "push",
    "workflow_run"
  ],
  "request_oauth_on_install": false,
  "setup_on_update": true
}
